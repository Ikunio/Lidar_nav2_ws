<?xml version="1.0"?>
<robot name="simple_car">

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="chassis"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <link name="chassis">
    <visual>
      <geometry><box size="0.4 0.3 0.1"/></geometry>
      <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.4 0.3 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.016" ixy="0.0" ixz="0.0" iyy="0.028" iyz="0.0" izz="0.041"/>
    </inertial>
  </link>

  <gazebo reference="chassis">
    <material>Gazebo/Blue</material>
  </gazebo>

  <link name="right_back_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <gazebo reference="right_back_wheel">
    <material>Gazebo/Black</material>
  </gazebo>

  <joint name="right_back_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="right_back_wheel"/>
    <origin xyz="-0.13 -0.205 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_back_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <gazebo reference="left_back_wheel">
    <material>Gazebo/Black</material>
  </gazebo>

  <joint name="left_back_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="left_back_wheel"/>
    <origin xyz="-0.13 0.205 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_top_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <gazebo reference="right_top_wheel">
    <material>Gazebo/Black</material>
  </gazebo>

  <joint name="right_top_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="right_top_wheel"/>
    <origin xyz="0.13 -0.205 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_top_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <gazebo reference="left_top_wheel">
    <material>Gazebo/Black</material>
  </gazebo>

  <joint name="left_top_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="left_top_wheel"/>
    <origin xyz="0.13 0.205 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Gazebo 控制插件 -->
  <gazebo>
    <plugin name="gazebo_ros_skid_steer_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>

      <num_wheel_pairs>2</num_wheel_pairs>

      <left_joint>left_top_wheel_joint</left_joint>
      <right_joint>right_top_wheel_joint</right_joint>

      <left_joint>left_back_wheel_joint</left_joint>
      <right_joint>right_back_wheel_joint</right_joint>

      <wheel_separation>0.41</wheel_separation>
      <wheel_diameter>0.20</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <publish_odom>false</publish_odom>
      <publish_odom_tf>false</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>


<!-- Mid-360 雷达传感器 -->
  <link name="livox_frame">

    <!-- 外观设置 -->
    <visual>
      <geometry><cylinder length="0.04" radius="0.035"/></geometry>
      <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
    </visual>

    <!-- 碰撞设置 -->
    <collision>   
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
    </collision>

    <!-- 惯性设置 -->
    <inertial>   
      <mass value="0.2"/>   <!-- 质量 -->
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- 链接 -->
  <joint name="livox_joint" type="fixed">
    <parent link="chassis"/>
    <child link="livox_frame"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- 雷达传感器设置 Gazebo 插件配置 -->
  <gazebo reference="livox_frame">
    <sensor type="ray" name="livox_mid360">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <visualize>false</visualize>
      <update_rate>10</update_rate>

      <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>50</samples>
              <resolution>1</resolution>
              <min_angle>-0.126</min_angle>
              <max_angle>0.963</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>40.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
      </ray>

      <plugin name="gazebo_ros_ray_sensor" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=/livox/lidar</remapping>   <!-- 强制映射 -->
        </ros>
        <output_type>sensor_msgs/PointCloud2</output_type>
        <frame_name>livox_frame</frame_name>
      </plugin>

    </sensor>


    <!-- imu 传感器 -->
    <sensor name="lidar_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate> <visualize>false</visualize>

      <plugin name="lidar_imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=/livox/imu</remapping> </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>

      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></z>
        </linear_acceleration>
      </imu>

    </sensor>
  </gazebo>

</robot>
